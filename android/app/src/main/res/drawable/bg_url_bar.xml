<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/toolbar_field" />
            <stroke
                android:width="1dp"
                android:color="@color/accent" />
            <corners android:radius="18dp" />
            <padding
                android:left="14dp"
                android:right="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/toolbar_field" />
            <stroke
                android:width="1dp"
                android:color="@color/toolbar_field_stroke" />
            <corners android:radius="18dp" />
            <padding
                android:left="14dp"
                android:right="14dp" />
        </shape>
    </item>
</selector>
